# ============================================================================
# VoiceHub 環境変数テンプレート
# ============================================================================
# このファイルを `.env.local` にコピーして値を埋めてください:
#   cp .env.example .env.local
#
# `NEXT_PUBLIC_` プレフィックスはクライアントバンドルに含まれる公開値です。
# それ以外はサーバー側のみで使用されます (Next.js の規約)。
# ============================================================================

# ----------------------------------------------------------------------------
# [必須] Supabase — 認証・データベース・ストレージ
# ----------------------------------------------------------------------------
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# サーバー側の admin client が RLS をバイパスして使用するキー (絶対公開しない)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# [推奨] アプリベース URL
# ----------------------------------------------------------------------------
# OG 画像 / sitemap / robots.txt / Stripe コールバック URL の生成に使用
# 未設定時は VERCEL_URL > "https://voicehub.jp" の順でフォールバック
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ----------------------------------------------------------------------------
# [オプション] ベータ機能ゲート
# ----------------------------------------------------------------------------
# "true" でベータ機能 (Pro プラン無料開放など) を有効化
NEXT_PUBLIC_BETA_MODE=false

# ----------------------------------------------------------------------------
# [オプション] Stripe — Pro プラン課金
# ----------------------------------------------------------------------------
# 課金フローを使わない場合は空欄でも `next dev` / `next build` は通る。
# ただし `/api/stripe/*` (checkout / portal / webhook) を叩くと 500 になる。
# Stripe ダッシュボード > Developers > API keys から取得
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe ダッシュボード > Products から Pro プランの price ID をコピー
STRIPE_PRO_PRICE_ID=price_xxx

# `stripe listen --forward-to localhost:3001/api/stripe/webhook` で取得
# 未設定時は webhook ハンドラが 500 ("Webhook not configured") を返す
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----------------------------------------------------------------------------
# [オプション] Upstash Redis — レート制限
# ----------------------------------------------------------------------------
# 未設定時はレート制限が no-op になる (開発時は省略可)
# https://console.upstash.com/ から REST URL/Token を取得
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ----------------------------------------------------------------------------
# [オプション] PostHog — プロダクトアナリティクス
# ----------------------------------------------------------------------------
# 未設定時はクライアント側の posthog.init() がスキップされる
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------------------
# [オプション] Google Places API — Google レビューインポート機能
# ----------------------------------------------------------------------------
# 未設定時はダッシュボードの「Google レビュー取り込み」機能が利用不可
# Google Cloud Console > APIs & Services > Credentials から取得
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ----------------------------------------------------------------------------
# [E2E テストのみ] Playwright 認証付きシナリオ
# ----------------------------------------------------------------------------
# `npm run test:e2e` で auth.setup.ts が使用するテストアカウント
E2E_USER_EMAIL=test@example.com
E2E_USER_PASSWORD=your-test-password

# Widget プレビューの E2E で対象を上書きする場合のみ指定
# TEST_WIDGET_ID=00000000-0000-0000-0000-000000000000
